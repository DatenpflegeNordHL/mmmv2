[flake8]
max-line-length = 180
extend-ignore =
    E203,
    E402,
    E501,
    F401,
    F403,
    F405,
    F811,
    F841,
    F541,
    E722,
    W503
per-file-ignores =
    mmm/ui/*.py: E501
    mmm/ui/banners.py: C901
    mmm/ui/console.py: C901
    mmm/ui/progress.py: C901
    mmm/**/*.py: E266
